13. Prime number
C++
#include <iostream>
using namespace std;

void checkPrime(int n) {
    int count=0;
    for(int i=1;i<=n;i++)
        if(n%i==0) count++;

    if(count==2)
        cout << "Prime";
    else
        cout << "Not Prime";
}

int main() {
    checkPrime(7);
}
14. Call by value & reference
C++
#include <iostream>
using namespace std;

void callByValue(int x) {
    x = x + 10;
}

void callByReference(int &x) {
    x = x + 10;
}

int main() {
    int a=5;
    callByValue(a);
    cout << "Value: " << a << endl;

    callByReference(a);
    cout << "Reference: " << a;
}
15. Pyramid pattern
C++
#include <iostream>
using namespace std;

void pyramid(int n) {
    for(int i=1;i<=n;i++) {
        for(int j=1;j<=i;j++)
            cout << j;
        cout << endl;
    }
}

int main() {
    pyramid(4);
}
16. Armstrong number
C++
#include <iostream>
using namespace std;

void checkArmstrong(int n) {
    int sum=0, temp=n;
    while(n>0) {
        int r=n%10;
        sum += r*r*r;
        n/=10;
    }

    if(sum==temp)
        cout << "Armstrong";
    else
        cout << "Not Armstrong";
}

int main() {
    checkArmstrong(153);
}
17. Average of N numbers
C++
#include <iostream>
using namespace std;

void average() {
    int n, sum=0, x;
    cin >> n;
    for(int i=0;i<n;i++) {
        cin >> x;
        sum += x;
    }
    cout << "Average: " << (float)sum/n;
}

int main() {
    average();
}
18. Area & Volume using constructor
C++
#include <iostream>
using namespace std;

class Box {
    float l,b,h;
public:
    Box(float x,float y,float z) {
        l=x; b=y; h=z;
    }
    void display() {
        cout << "Area: " << 2*(l*b + b*h + h*l) << endl;
        cout << "Volume: " << l*b*h;
    }
};

int main() {
    Box obj(2,3,4);
    obj.display();
}
19. Time addition
C++
#include <iostream>
using namespace std;

class Time {
public:
    int h,m,s;

    void add(Time t1, Time t2) {
        s = t1.s + t2.s;
        m = t1.m + t2.m + s/60;
        h = t1.h + t2.h + m/60;

        s%=60;
        m%=60;
    }

    void display() {
        cout << h << ":" << m << ":" << s;
    }
};

int main() {
    Time t1={1,50,40}, t2={2,20,30}, t3;
    t3.add(t1,t2);
    t3.display();
}
20. Single Inheritance
C++
#include <iostream>
using namespace std;

class A {
public:
    void show() {
        cout << "Base class";
    }
};

class B : public A {
public:
    void display() {
        cout << "Derived class";
    }
};

int main() {
    B obj;
    obj.show();
    obj.display();
}
