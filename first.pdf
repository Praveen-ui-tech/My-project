5. Fibonacci series
C++
#include <iostream>
using namespace std;

void fibonacci(int n) {
    int a=0, b=1, c;
    for(int i=1;i<=n;i++) {
        cout << a << " ";
        c = a + b;
        a = b;
        b = c;
    }
}

int main() {
    fibonacci(10);
}
6. Factorial using recursion
C++
#include <iostream>
using namespace std;

int factorial(int n) {
    if(n==0) return 1;
    return n * factorial(n-1);
}

int main() {
    cout << factorial(5);
}
7. Decimal to Binary
C++
#include <iostream>
using namespace std;

void decimalToBinary(int n) {
    int binary[32], i=0;
    while(n>0) {
        binary[i++] = n%2;
        n/=2;
    }
    for(int j=i-1;j>=0;j--)
        cout << binary[j];
}

int main() {
    decimalToBinary(10);
}
8. Palindrome string
C++
#include <iostream>
using namespace std;

void checkPalindrome(string str) {
    string rev = "";
    for(int i=str.length()-1;i>=0;i--)
        rev += str[i];

    if(str == rev)
        cout << "Palindrome";
    else
        cout << "Not Palindrome";
}

int main() {
    checkPalindrome("madam");
}
9. Reverse digits
C++
#include <iostream>
using namespace std;

void reverseNumber(int n) {
    int rev=0;
    while(n>0) {
        rev = rev*10 + n%10;
        n/=10;
    }
    cout << rev;
}

int main() {
    reverseNumber(1234);
}
10. Sum of two matrices
C++
#include <iostream>
using namespace std;

void addMatrix() {
    int a[2][2]={{1,2},{3,4}}, b[2][2]={{5,6},{7,8}}, c[2][2];

    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            c[i][j] = a[i][j] + b[i][j];

    for(int i=0;i<2;i++) {
        for(int j=0;j<2;j++)
            cout << c[i][j] << " ";
        cout << endl;
    }
}

int main() {
    addMatrix();
}
11. Matrix multiplication
C++
#include <iostream>
using namespace std;

void multiplyMatrix() {
    int a[2][2]={{1,2},{3,4}}, b[2][2]={{5,6},{7,8}}, c[2][2]={0};

    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            for(int k=0;k<2;k++)
                c[i][j] += a[i][k]*b[k][j];

    for(int i=0;i<2;i++) {
        for(int j=0;j<2;j++)
            cout << c[i][j] << " ";
        cout << endl;
    }
}

int main() {
    multiplyMatrix();
}
