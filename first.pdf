1.Swap two variables (using function)
C++
#include <iostream>
using namespace std;

void swapNumbers(int &a, int &b) {
    int temp = a;
    a = b;
    b = temp;
}

int main() {
    int x = 5, y = 10;
    swapNumbers(x, y);
    cout << "After swap: " << x << " " << y;
    return 0;
}
2. Roots of Quadratic Equation
C++
#include <iostream>
#include <cmath>
using namespace std;

void findRoots(float a, float b, float c) {
    float d = b*b - 4*a*c;

    if (d > 0)
        cout << "Roots are real and different";
    else if (d == 0)
        cout << "Roots are equal";
    else
        cout << "Roots are imaginary";
}

int main() {
    findRoots(1, -3, 2);
    return 0;
}
3. Area using switch case
C++
#include <iostream>
using namespace std;

void area(int choice) {
    float r, l, b, s;

    switch(choice) {
        case 1:
            cin >> r;
            cout << "Circle Area: " << 3.14*r*r;
            break;
        case 2:
            cin >> l >> b;
            cout << "Rectangle Area: " << l*b;
            break;
        case 3:
            cin >> s;
            cout << "Square Area: " << s*s;
            break;
    }
}

int main() {
    area(1);
    return 0;
}
4. Table of a number
C++
#include <iostream>
using namespace std;

void printTable(int n) {
    for(int i=1; i<=10; i++)
        cout << n << " x " << i << " = " << n*i << endl;
}

int main() {
